Package 		Astarte_BoxesImp 

			Implements "boxes"
===============================================================

Import "listfun".

===============================================================
%% 			@#_
%% 			@#
===============================================================

Let ?a @#_ ?i = @(a #_ i).
Let ?a @# ?i = @(a # i).

===============================================================
%% 			unknownArray
%% 			sharedUnknownArray
%% 			nonsharedUnknownArray
%% 			infiniteUnknownArray
%% 			infiniteSharedUnknownArray
%% 			infiniteNonsharedUnknownArray
===============================================================

Let makeUnknown ?p_flav ()	  = newUnknown p_flav.

Let unknownArray ?p_flav          = varDup (makeUnknown p_flav) ().
Let sharedUnknownArray		  = unknownArray shared.
Let nonsharedUnknownArray	  = unknownArray nonshared.

Let infiniteUnknownArray ?p_flav    = infVarDup (makeUnknown p_flav) () ().
Let infiniteSharedUnknownArray()    = infiniteUnknownArray shared.
Let infiniteNonsharedUnknownArray() = infiniteUnknownArray nonshared.

===============================================================
%%			arrayInit
===============================================================

Let arrayInit ?p_flav ?n ?x = a |

    %%-----------------------
    %% Build the array.
    %%-----------------------
    
    Let a = array p_flav n.

    %%-----------------------------
    %% Initialize the boxes.
    %%-----------------------------
    
    Loop (?l_a, ?l_x) = (a, x) first
      exitcase nil? l_x => ()
      exitcase nil? l_a => ()
      loopcase else   => 
        AssignInit head l_a := head l_x.
        continue (tail l_a, tail l_x)
    %Loop
%Let

===============================================================
%%			array
%%			arrayNoinit
===============================================================

Let array ?p_flav ?x = arrayInit p_flav (length x) x.

Let arrayNoinit ?p_flav ?n () = array p_flav n.

===============================================================
%%			fullArray
%%			fullSharedArray
%%			fullNonsharedArray
===============================================================

Let fullArray ?p_flav ?p_init ?i = l_result |
  Let l_result = array p_flav i.
  FillInit!! l_result := p_init.
%Let

Let fullSharedArray    = fullArray shared.
Let fullNonsharedArray = fullArray nonshared.

===============================================================
%%			infiniteArray
%%			infiniteSharedArray
%%			infiniteNonsharedArray
===============================================================
%% infiniteArrayHelp i flav x produces an infinite array
%% initialized to list x.  (If x is finite, then only a
%% prefix is initialized.)  The array is created in pieces, 
%% where the first piece has size i.
%%----------------------------------------------------------------

Define infiniteArrayHelp ?i ?p_flav ?x =
  If nil? x 
    then infiniteArray p_flav 
    else
      Await then
        (arrayInit p_flav i x) ++ 
	(infiniteArrayHelp (i+i) p_flav (drop i x))
      %Await
  %If
%Define

Let infiniteArray          = infiniteArrayHelp 4.
Let infiniteSharedArray    = infiniteArray shared.
Let infiniteNonsharedArray = infiniteArray nonshared.

===============================================================
%% 			infiniteArrayInit
%%			infiniteArrayNoinit
===============================================================

Let infiniteArrayInit   ?p_flav () ?x = infiniteArray p_flav x.
Let infiniteArrayNoinit ?p_flav () () = infiniteArray p_flav.


===============================================================
%% 			varDup
===============================================================

Let varDup ?f ?n ?m =

  %%----------------------------------------------------
  %% Build the list backwards, calling f(n) repeatedly.
  %%----------------------------------------------------
  
  Loop (?l_result, ?l_cnt) = ([], 0) first
    exitcase l_cnt == m => l_result
    loopcase else       => continue ([f(n) & l_result], l_cnt + 1)
  %Loop
  
  %%-----------------------------------------------------
  %% Now reverse to get the correct order, and then pack.
  %%-----------------------------------------------------
  
  | reverse 
  | pack
%Let  

===============================================================
%%			infVarDup
===============================================================
%% infVarDup uses helper infdup(f,n,m) which creates an infinite
%% list [f(n), f(n), ...] in chunks, starting with chunk size m.
%% The chunks become successively larger as the list is built.
%%----------------------------------------------------------------

Define infdup(?f,?n,?m)   = (: varDup f n m ++ infdup(f,n,m+m) :).
Let     infVarDup ?f ?n () = infdup(f,n,4).

===============================================================
%% 			varDupInit
%%			varDupNoinit
===============================================================

Define varDupInitHelp(?f,?g,?n,?x) =
  Choose
    case n == 0 => []
    case nil? x => varDup g () n
    else        => f(head x) :: varDupInitHelp(f,g,n--1,tail x)
  %Choose
%Define

Let varDupInit (?f,?g) ?n ?x = pack(varDupInitHelp (f,g,n,x)).

Let varDupNoinit ?f ?n = fdup n f.

===============================================================
%% 			infVarDupInit
%%			infVarDupNoinit
===============================================================

Define infdupinit(?f,?g,?x,?m) = 
  (: varDupInit (f,g) m x ++ infdupinit(f, g, drop m x, m+m) :)
%Define

Let infVarDupInit (?f,?g) () ?x = infdupinit(f,g,x,4).

Define infFdupHelp (?f,?m) = (fdup m f) ++ infFdupHelp(f,m+m).
Let infFdup ?f = infFdupHelp (f,4).
Let infVarDupNoinit ?f () = infFdup f.

===============================================================
%% 			fullInfiniteArray
%% 			fullInfiniteSharedArray
%% 			fullInfiniteNonsharedArray
===============================================================
%% fullInfiniteArray uses helper function 
%% fullinfarray (p_flav,p_init,i) that
%% creates an infinite array [<:p_init:>, <:p_init:>,...] in
%% chunks, the first chunk having size i.  The chunks are
%% progressively larger as the array is built.
%%----------------------------------------------------------------

Define fullinfarray (?p_flav, ?p_init, ?i) = 
  (: fullArray p_flav p_init i ++ fullinfarray(p_flav, p_init, i+i) :)
%Define

Let fullInfiniteArray ?p_flav ?p_init () = 
  fullinfarray (p_flav, p_init, 4)
%Let

Let fullInfiniteSharedArray    = fullInfiniteArray shared.
Let fullInfiniteNonsharedArray = fullInfiniteArray nonshared.

===============================================================
%% 			nonemptyPrefix
===============================================================

Define nonemptyPrefix ?l =
  Choose
    case nil? l                => []
    case not emptyBox?(head l) => (head l) :: nonemptyPrefix(tail l)
    else                       => []
  %Choose
%Define

