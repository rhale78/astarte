Package testshow 

%% Test Show function

Define l1 = [1,2].
Define l2 = [3,4].
Define l3 = [].

Execute
  Writeln[].
  Show @stdout!, l1.
  Writeln[].
  Let a = l1 ++ l2 ++ l3.
  Show @stdout!, a.
  Writeln[].
  Let f ?x = x.
  Show @stdout!, f.
  Writeln[].

  Let g () = 
    Let h ?x = x.
    Show @stdout!, h.
    Writeln[].
  %Let
  (g())
  Writeln[].
%Execute

%Package

  
