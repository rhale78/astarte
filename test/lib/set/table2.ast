Package TestTable2 

%% Test Package sparstbl.ast, operations:
%%   sparseMemoize

Directory standard.
Import "collect/sparstbl".
Default TABLE => SparseTable.

Team
  Define fib = sparseMemoize fibb.
  Define fibb(?n) =
    If n <= 1
      then n
      else fib(n--1) + fib(n--2)
    %If
  %Define
%Team

Execute
  Writeln["Table of fibonacci numbers\n"].
  For ?i from 0 _upto_ 20 do
    Writeln[i $$ 5, fib(i) $$ 10].
  %For
%Execute

%Package

