Package testfunctional2 

%% An example using listops.ast.

Import "collect/listfun"; "misc/check".

Define prime?(?n) =
  Choose first
    case n < 2  => false
    case n == 2 => true
    else        =>
    (dup (n--2) n, 2 _upto_ (n--1)) 
      | _zip_ | map (_mod_) | min | zero? | not
  %Choose
%Define

Execute
  Line ["   2 ", prime?(2) | $].
  Check["   2 true"].
  Line ["   3 ", prime?(3) | $].
  Check["   3 true"].
  Line ["   4 ", prime?(4) | $].
  Check["   4 false"].
  Line ["   5 ", prime?(5) | $].
  Check["   5 true"].
  Line ["   6 ", prime?(6) | $].
  Check["   6 false"].
  Line [" 100 ", prime?(100) | $].
  Check[" 100 false"].
  Line [" 143 ", prime?(143) | $].
  Check[" 143 false"].
%Execute

%Package
