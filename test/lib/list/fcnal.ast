Package TestListops 

%% Test functions in listops.ast, and standard functionals.

Import "collect/listfun"; "collect/search"; "collect/pair"; "misc/check".

%% _o_

Execute
  Let a = ((-) _o_ (-)) (6,2).
  Line[a $$ 10].
  Check["        -4"].
%Execute

%% __

Execute
  Let a = (__ > 2) (5).
  Line[$a].
  Check["true"].
%Execute

%% __/-

Execute
  Let f ?x ?y = x - y.
  Let g = __/- f.
  Let a = g(6,2).
  Line[$a].
  Check["-4"].
%Execute


%% _pmap_

Execute
  Let a = ((+) _pmap_ (-))((3,2),(3,2)).
  Line[$a].
  Check["(5,1)"].
%Execute

%% _tee_

Execute
  Let a = ((+) _tee_ (-))(3,2).
  Line[$a].
  Check["(5,1)"].
%Execute

%% map, eagerMap

Operator mappedBy(#).
Let ?l mappedBy ?f = map f l.

Execute
  Let x =  map (+) [(1,2), (3,4), (5,6)].
  Line (x mappedBy (__ $$ 5)).
  Check["    3    7   11"].
  Let y = map (__ + 1) (2 _upto_ 4).
  Line (y mappedBy (__ $$ 5)).
  Check["    3    4    5"].
  Let z =  eagerMap (+) [(1,2), (3,4), (5,6)].
  Line (z mappedBy (__ $$ 5)).
  Check["    3    7   11"].
  Let w = eagerMap (__ + 1) (2 _upto_ 4).
  Line (w mappedBy (__ $$ 5)).
  Check["    3    4    5"].
%Execute

%% filter

Execute
  Let x = filter (__ > 7) [10,2,11,4,7].
  Line[$x].
  Check["[10,11]"].
  Let y = filter (odd?) (1 _upto_ 1000000).
  Line[$(y#_0), ",", $(y#_2)].
  Check["1,5"].
%Execute

%% rfold, lfold, bfold

Execute
  Let n = rfold (0,+) [2,3,4].
  Line[$n].
  Check["9"].
  Let m = rfold (0,+) (1 _upto_ 10).
  Line[$m].
  Check["55"].
  Let p = lfold (0, +) [2,3,4].
  Line[$p].
  Check["9"].
  Let q = lfold (0, +) (1 _upto_ 10).
  Line[$q].
  Check["55"].
  Let r = bfold (0, +) [2,3,4].
  Line[$r].
  Check["9"].
  Let s = bfold (0, +) (1 _upto_ 10).
  Line[$s].
  Check["55"].
%Execute

%% unfold, _cutBy_, _eagerCutBy_

Execute
  Let sqr ?x = x * x.
  Let x = unfold (sqr) 2.
  Match (?y,?) = x _cutBy_ (__ > 100).
  Line[$y].
  Check["[2,4,16]"].
  Match (?z,?w) = [1,2,4,100,101,103] _eagerCutBy_ (__ > 100).
  Line[$z].
  Check["[1,2,4,100]"].
  Line[$w].
  Check["[101,103]"].
%Execute

%% bpartition

Execute
  Match (?a,?b) = bpartition (__ > 10) [10,3,100,33,2,19].
  Line[$a].
  Check["[100,33,19]"].
  Line[$b].
  Check["[10,3,2]"].
%Execute

%% partition

Execute
  Match [?a,?b,?c] = partition [__ > 100, __ > 10] [1,200,30,2,80,600].
  Line[$a].
  Check["[200,600]"].
  Line[$b].
  Check["[30,80]"].
  Line[$c].
  Check["[1,2]"].
%Execute

%% _zip_, unzip

Execute
  Let l = [1,2,3] _zip_  [4,5,6].
  Line[$l].
  Check["[(1,4),(2,5),(3,6)]"].
  Match (?a,?b) = unzip l.
  Line[$a].
  Check["[1,2,3]"].
  Line[$b].
  Check["[4,5,6]"].
%Execute

%% _quickZip_, unzip

Execute
  Let l = [1,2,3] _quickZip_ [4,5,6].
  Line[$l].
  Check["[(1,4),(2,5),(3,6)]"].
  Match (?a,?b) = unzip l.
  Line[$a].
  Check["[1,2,3]"].
  Line[$b].
  Check["[4,5,6]"].
%Execute

%% _in_

Execute
  Let a = _in_(2, [1,2,3]).
  Let b = _in_(2, [1,3,5]).
  Let c = _in_(2, nil).
  Line[$a, " ", $b, " ", $c].
  Check["true false false"].
%Execute

%% someSatisfy

Execute
  Let a = someSatisfy (__ > 4) [2,4,6].
  Let b = someSatisfy (__ > 4) [2,4].
  Let c = someSatisfy (__ > 4) [].
  Line[$a, " ", $b, " ", $c].
  Check["true false false"].
%Execute

%% allSatisfy

Execute
  Let a = allSatisfy (__ < 7) [2,4,6].
  Let b = allSatisfy (__ > 4) [2,4].
  Let c = allSatisfy (__ > 4) [].
  Let d = allSatisfy (__ > 4) [2,4,6].
  Line[$a, " ", $b, " ", $c, " ", $d].
  Check["true false true false"].
%Execute

%% indexedList

Execute
  Let a = indexedList 0 [(2,5),(6,7)].
  Line[$a].
  Check["[0,5,0,0,0,7]"].
  Let b = indexedList 0 [].
  Line[$b].
  Check["[]"].
  Let c = indexedList 100 [(1,1), (4,4)].
  Line[$c].
  Check["[1,100,100,4]"].
%Execute

%Package  
