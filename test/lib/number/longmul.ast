Package longtestmult 

%% Test integer multiplication For a multitude of sizes of numbers.

Execute
  Let badcnt = box(0).
  Loop (?i,?p) = (1,10) perhaps
  loopcase i < 400 =>
    Writeln["Product ", $p].
    Loop (?j,?k,?a,?b) = (1,i--1,10,p _div_ 10) perhaps
    loopcase k >= 1 =>
      Let c = a*b.
      If c =/= p then 
	Writeln["Bad product:"].
	Writeln["a   = ", $a].
        Writeln["b   = ", $b].
	Writeln["a*b = ", $c].
        Increment badcnt.
      %If
      Let d = (a _div_ 2)*(b _div_ 2).
      If d =/= p _div_ 4 then 
	Writeln["Bad product:"].
	Writeln["a   = ", $(a _div_ 2)].
        Writeln["b   = ", $(b _div_ 2)].
	Writeln["a*b = ", $d].
        Increment badcnt.
      %If
      Writeln[j$$5,k$$5].
      continue (j+1, k--1, a*10, b _div_ 10)
    %Loop
    continue (i+1, 10*p)
  %Loop
  Writeln["\n There were ", $ @badcnt, " bad cases"].
%Execute

%Package
