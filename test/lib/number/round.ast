Package Round 

%% test round, floor, ceiling

Import "misc/check".

Execute
  Line[$round(1.3), " ", $round(1.6), " ", $round(-1.3), " ", $round(-1.6)].
  Check["1 2 -1 -2"].
  Line[$floor(1.3), " ", $floor(1.6), " ", $floor(-1.3), " ", $floor(-1.6)].
  Check["1 1 -2 -2"].
  Line[$ceiling(1.3), " ", $ceiling(1.6), " ", $ceiling(-1.3), " ", $ceiling(-1.6)].
  Check["2 2 -1 -1"].
%Execute

%Package
