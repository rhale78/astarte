Package testreal3 

%% Test multiplication and division of rationals and reals.

Import "misc/check".

%% Rational multiplication and division.

Execute
  Line[(0/1) * (0/1) $$ 25].
  Check["                        0"].
  Line[(1/2) * (0/1) $$ 25].
  Check["                        0"].
  Line[(1/2) * (1/3) $$ 25].
  Check["                      1/6"].
  Line[(2/1) * (1/3) $$ 25].
  Check["                      2/3"].
  Line[(2/1) * (1/2) $$ 25].
  Check["                        1"].
  Line[(10/6) * (12/5) $$ 25].
  Check["                        4"].

  Line[(0/1) / (1/1) $$ 25].
  Check["                        0"].
  Line[(1/2) / (1/3) $$ 25].
  Check["                      3/2"].
  Line[(2/1) / (1/3) $$ 25].
  Check["                        6"].
  Line[(2/1) / (1/2) $$ 25].
  Check["                        4"].
  Line[(10/6) / (12/5) $$ 25].
  Check["                    25/36"].
%Execute

%% Real multiplication and division.

Execute
  Line[~0.0 * ~0.0 $$ (25,1)].
  Check["                      0.0"].
  Line[~1.0 * ~0.0 $$ (25,1)].
  Check["                      0.0"].
  Line[~6.0 * ~7.0 $$ (25,1)].
  Check["                     42.0"].
  Line[~(-6.0) * ~70.0 $$ (25,1)].
  Check["                   -420.0"].

  Line[~0.0 / ~1.0 $$ (25,1)].
  Check["                      0.0"].
  Line[~6.0 / ~7.0 $$ (20,15)].
  Check["   0.857142857142857"].
  Line[~(-6.0) / ~70.0 $$ (20,16)].
  Check[" -0.0857142857142857"].
%Execute

Execute
  Assign precision! := 50.
  Line[~6.0 * ~7.0 $$ 50].
  Check[" 4.200000000000000000000000000000000000000000E+001"].
  Line[~(-6.0) * ~7.0 $$ 50].
  Check["-4.200000000000000000000000000000000000000000E+001"].
  Line[~(6.0) / ~7.0 $$ 50].
  Check[" 8.571428571428571428571428571428571428571429E-001"].
  Line[~(-6.0) / ~7.0 $$ 50].
  Check["-8.571428571428571428571428571428571428571429E-001"].
%Execute

%Package
