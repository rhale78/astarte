Package testint1 

%% Test of addition and subtraction on integers.

Import "misc/check".

%% Small integers: +

Execute
	Line [0 + 0 $$ 20].
	Check["                   0"].
	Line [0 + 3 $$ 20].
	Check["                   3"].
	Line [3 + 0 $$ 20].
	Check["                   3"].
	Line [-3 + (0) $$ 20].
	Check["                  -3"].
	Line [(0) + -3 $$ 20].
	Check["                  -3"].
	Line [100 + 200 $$ 20].
	Check["                 300"].
	Line [-100 + (200) $$ 20].
	Check["                 100"].
	Line [(100) + (-200) $$ 20].
	Check["                -100"].
	Line [-100 + (-200) $$ 20].
	Check["                -300"].
	Line [1000 + 2456 $$ 20].
	Check["                3456"].
	Line [-1000 + (333) $$ 20].
	Check["                -667"].
	Line [(1000) + (-333) $$ 20].
	Check["                 667"].
	Line [-1000 + (-333) $$ 20].
	Check["               -1333"].
%Execute

%% Small integers: -

Execute
	Line [0 - (+ 0) $$ 20].
	Check["                   0"].
	Line [0 - (+ 3) $$ 20].
	Check["                  -3"].
	Line [3 - (+ 0) $$ 20].
	Check["                   3"].
	Line [-3 - (+ 0) $$ 20].
	Check["                  -3"].
	Line [0 - -3 $$ 20].
	Check["                   3"].
	Line [100 - (200) $$ 20].
	Check["                -100"].
	Line [-100 - (200) $$ 20].
	Check["                -300"].
	Line [100 - (-200) $$ 20].
	Check["                 300"].
	Line [-100 - (-200) $$ 20].
	Check["                 100"].
	Line [1000 - (2456) $$ 20].
	Check["               -1456"].
	Line [-1000 - (333) $$ 20].
	Check["               -1333"].
	Line [1000 - (-333) $$ 20].
	Check["                1333"].
	Line [-1000 - (-333) $$ 20].
	Check["                -667"].
%Execute

%% Small integers: --

Execute
	Line [0 -- 0 $$ 20].
	Check["                   0"].
	Line [0 -- 2 $$ 20].
	Check["                   2"].
	Line [100 -- 20 $$ 20].
	Check["                  80"].
	Line [100 -- 101 $$ 20].
	Check["                   1"].
%Execute

%% Larger integers: +

Execute
	Line [4269504088896 + 1 $$ 20].
	Check["       4269504088897"].
	Line [10000000 + 1 $$ 20].
	Check["            10000001"].
	Line [100000 + 2000000 $$ 20].
	Check["             2100000"].
	Line [-100000 + (2000000) $$ 20].
	Check["             1900000"].
	Line [(100000) + (-2000000) $$ 20].
	Check["            -1900000"].
	Line [-100000 + (-2000000) $$ 20].
	Check["            -2100000"].
	Line [123456789 + 1 $$ 20].
	Check["           123456790"].
	Line [-123456789 + (1) $$ 20].
	Check["          -123456788"].
	Line [1234567891234567 + 1 $$ 20].
	Check["    1234567891234568"].
	Line [9999999999999999 + 1 $$ 20].
	Check["   10000000000000000"].
	Line [-9999999999999999 + (-1) $$ 20].
	Check["  -10000000000000000"].
%Execute

%% Larger integers: -

Execute
	Line [10000000 - (1) $$ 20].
	Check["             9999999"].
	Line [100000 - (2000000) $$ 20].
	Check["            -1900000"].
	Line [-100000 - (2000000) $$ 20].
	Check["            -2100000"].
	Line [100000 - (-2000000) $$ 20].
	Check["             2100000"].
	Line [-100000 - (-2000000) $$ 20].
	Check["             1900000"].
	Line [123456789 - (+ 1) $$ 20].
	Check["           123456788"].
	Line [-123456789 - (+ 1) $$ 20].
	Check["          -123456790"].
	Line [1234567891234567 - (+ 1) $$ 20].
	Check["    1234567891234566"].
	Line [10000000000000000 - (1) $$ 20].
	Check["    9999999999999999"].
	Line [-10000000000000000 - (-1) $$ 20].
	Check["   -9999999999999999"].
%Execute

%% Larger integers: --

Execute
	Line [4269504088896 -- 1 $$ 20].
	Check["       4269504088895"].
	Line [1000000000 -- 999999999 $$ 20].
	Check["                   1"].
	Line [1000000000 -- 1000000001 $$ 20].
	Check["                   1"].
%Execute


%% Large integers: +

Execute
	Line [123456789123456789+123456789123456789 $$ 39].
	Check["                     246913578246913578"].
	Line [-123456789123456789+(+ 123456789123456789) $$ 39].
	Check["                                      0"].
	Line [-123456789123456789 + (-123456789123456789) $$ 39].
	Check["                    -246913578246913578"].
	Line [9999999999999999999999999999999999999 + 1 $$ 39].
	Check[" 10000000000000000000000000000000000000"].

%Execute

%% Large integers: -

Execute
	Line [123456789123456789-123456789123456789 $$ 39].
	Check["                                      0"].
	Line [-123456789123456789-(123456789123456789) $$ 39].
	Check["                    -246913578246913578"].
	Line [123456789123456789 - (-123456789123456789) $$ 39].
	Check["                     246913578246913578"].
	Line [100000000000000000000000000000000000000 - 1 $$ 39].
	Check[" 99999999999999999999999999999999999999"].
    %Execute

%% Even larger integers

Execute
	Writeln["Longer numbers\n"].
	Line[123456789123456789123456789123456789 + 1 $$ 56].
	Check["                    123456789123456789123456789123456790"].
	Line[123456789123456789123456789123456789 -- 1 $$ 56].
	Check["                    123456789123456789123456789123456788"].
        Line [123456789123456789123456789123456789 +
		123456789123456789123456789123456789123456789123456789 $$ 56]
	%Line
	Check["  123456789123456789246913578246913578246913578246913578"].
        Line [-123456789123456789123456789123456789 -
		(123456789123456789123456789123456789123456789123456789) $$ 56]
	%Line
	Check[" -123456789123456789246913578246913578246913578246913578"].

        Line [123456789123456789123456789123456789 -
		123456789123456789123456789123456789123456789123456789 $$ 56]
	%Line
	Check[" -123456789123456789000000000000000000000000000000000000"].
    %Execute
%Package




