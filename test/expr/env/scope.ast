Package testscope 

%% Test scoping rules -- should not compile.

=================================================================
%% Procedure application, []

Execute
  %% Should complain that a is not known.

  Writeln
    [Let a = "hello".
    a]
  %Writeln
  Writeln[a].

  %% Should complain about b.

  open Writeln
    [Let b = "hello".
    b]
  %Writeln
  Writeln[b].
%Execute

=================================================================
%% Let

Execute
  %% Should complain that a is not known.

  Let x =
    Let a = "hello".
    Writeln[a].
  %Let
  Writeln[a].

  %% Should not complain about b.

  open Let y =
    Let b = "hello".
    Writeln[b].
  %Let
  Writeln[b].
%Execute

=================================================================
%% Define

Execute
  %% Should complain that a is not known.

  Define x =
    Let a = "hello".
    Writeln[a].
  %Define
  Writeln[a].

  %% Should produce a syntax error

  open Define y =
    Let b = "hello".
    Writeln[b].
  %Define
  Writeln[b].
%Execute

=================================================================
%% Match

Execute
  %% Should complain that a is not known.

  Match ?x =
    Let a = "hello".
    Writeln[a].
  %Match
  Writeln[a].

  %% Should not complain about b.

  open Match ?y =
    Let b = "hello".
    Writeln[b].
  %Match
  Writeln[b].
%Execute

=================================================================
%% Atomic

Execute
  %% Should complain that a is not known.

  Atomic
    Let a = "hello".
    Writeln[a].
  %Atomic
  Writeln[a].

  %% Should not complain about b.

  open Atomic
    Let b = "hello".
    Writeln[b].
  %Atomic
  Writeln[b].
%Execute

