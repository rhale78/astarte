Package testteam2

%% Test Team expressions

Import "misc/check".

Define merge ?x ?y =
 Await then
   Choose first matching (x,y)
      case ([], ?a) 	        => a
      case (?a, []) 	        => a
      case (?a :: ?b, ?c :: ?d) => 
	Choose first
	  case a == c => a :: merge b d
	  case a < c  => a :: merge b y
	  else        => c :: merge x d
	%Choose
   %Choose
 %Await
%Define	     
=========================================================
Define PrintHamming ?n. =
  Team
    Define 
      hamming = 1 :: merge twos (merge threes fives);
      twos    = [: 2 * x | Let x = each hamming. :];
      threes  = [: 3 * x | Let x = each hamming. :];
      fives   = [: 5 * x | Let x = each hamming. :];
    %Define 
  %Team

  Loop ?i = 0 first
    loopcase i < n => Moreline[hamming#_i $$ 4].
	              continue i+1
    exitcase else  => ()
  %Loop
%Define

Execute
  Line[].
  PrintHamming 16.
  Check["   1   2   3   4   5   6   8   9  10  12  15  16  18  20  24  25"].
%Execute

%Package
