Package testenv 

%% Test the local environment handling

Import "misc/check".

Execute

  %% Basic

  Let a = 5.
  Let b = 10 + a.
  Let f ?x = a + x.
  Let c = 30.
  Let d = b + f c.
  Line[a $$ 10, b $$ 10, c $$ 10, d $$ 10].
  Check["         5        15        30        50"].

  %% Environment copying

  Var bg.
  CloseScope
    Let e = 20.
    Let g ?x = x + a + e.
    Assign bg := g.
  %CloseScope
  Let r = 9.
  Let s = (@bg)(r).
  Line[r $$ 5, s $$ 5].
  Check["    9   34"].
%Execute

Execute
  %% Nonlocal ids

  Let a = 1.
  Let f(?x) =
    Let g(?y) =
      Let h (?z) = a + x + y + z.
      (h 8)
    %Let
    (g 4)
  %Let
  Line[$(f 2)].
  Check["15"].
%Execute

%Package
