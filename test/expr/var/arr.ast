    For ?m from 0 _upto_ 1 do
      Moreline[$(@(asI2#_n#_m))].
    %For
  %For
  Check["333333333333"].

  Line[].
  For ?n from 0 _upto_ 4 do
    For ?m from 0 _upto_ 4 do
      Assign asII#_n#_m := 3.
    %For
  %For
  For ?n from 0 _upto_ 4 do
    For ?m from 0 _upto_ 4 do
      Moreline[$(@(asII#_n#_m))].
    %For
  %For
  Check["3333333333333333333333333"].

%Execute
=================================================================

==============================================================
Execute
  Var{shared, unknown} asu(5) holding Natural.
  Var{shared, unknown} asI(*) holding Natural.
  Var{shared, unknown} as2i(2,3) holding Natural.
  Var{shared, unknown} as2I(2,*) holding Natural.
  Var{shared, unknown} asI2(*,2) holding Natural.
  Var{shared, unknown} asII(*,*) holding Natural.

  Writeln["SharedUnknowns"].
  For ?n from 0 _upto_ 4 do BindUnknown asu#_n := 6..
  Line[].
  For ?n from 0 _upto_ 4 do Moreline[$(asu#_n)]..
  Check["66666"].

  For ?n from 0 _upto_ 9 do BindUnknown asI#_n := 6..
  Line[].
  For ?n from 0 _upto_ 9 do Moreline[$(asI#_n)]..
  Check["6666666666"].

  Line[].
  For ?n from 0 _upto_ 1 do
    For ?m from 0 _upto_ 2 do
      BindUnknown as2i#_n#_m := 3.
    %For
  %For
  For ?n from 0 _upto_ 1 do
    For ?m from 0 _upto_ 2 do
      Moreline[$(as2i#_n#_m)].
    %For
  %For
  Check["333333"].

  Line[].
  For ?n from 0 _upto_ 1 do
    For ?m from 0 _upto_ 5 do
      BindUnknown as2I#_n#_m := 3.
    %For
  %For
  For ?n from 0 _upto_ 1 do
    For ?m from 0 _upto_ 5 do
      Moreline[$(as2I#_n#_m)].
    %For
  %For
  Check["333333333333"].

  Line[].
  For ?n from 0 _upto_ 5 do
    For ?m from 0 _upto_ 1 do
      BindUnknown asI2#_n#_m := 4.
    %For
  %For
  For ?n from 0 _upto_ 5 do
    For ?m from 0 _upto_ 1 do
      Moreline[$(asI2#_n#_m)].
    %For
  %For
  Check["444444444444"].

  Line[].
  For ?n from 0 _upto_ 4 do
    For ?m from 0 _upto_ 4 do
      BindUnknown asII#_n#_m := 3.
    %For
  %For
  For ?n from 0 _upto_ 4 do
    For ?m from 0 _upto_ 4 do
      Moreline[$(asII#_n#_m)].
    %For
  %For
  Check["3333333333333333333333333"].

%Execute
=================================================================

  
%Package
