Package StringStack

  Import "object".
  Import "misc/check".

  Extension
    Class StringStack
      Const size : Natural.          %% The physical size of an array that
                                     %% holds the stack contents.

      Var 
        depth holding Natural := 0;     %% The current number of members
        content(my size) holding String %% The stack contents
      %Var

      Expect
        Push  : String -> ();
        pop   : ()     -> String;
        Empty : ()     -> ();
        empty?: ()     -> Boolean
      %Expect
    %Class
  %Extension

   Exception 
     trap stackUnderflowX; 
     trap stackOverflowX
   %Exception

   Define Ask StringStack ?s => empty?() %Ask =
     @(my depth) == 0
   %Define

   Define Ask StringStack ? => 
            Empty. 
          %Ask =
     Assign my depth := 0.
   %Define

   Define Ask StringStack ? => pop() %Ask =
     If my empty?() then 
       fail stackUnderflowX
     else
       Let currentIndex = @(my depth).
       Decrement my depth.
       Value @( my content # currentIndex ).
     %If
   %Define

   Define Ask StringStack ? => 
            Push(?s). 
          %Ask =
     If @(my depth) >= my size then
       fail stackOverflowX
     else
       Increment my depth.
       Assign (my content) # (@my depth) := s.
     %If
   %Define

  Define StringStack constructor
    stringStack(?my   size) =
      ()
    then
      Assign my depth := 0.
  %Define

  Define StringStack constructor
    altstringStack(?my-size) = ()
  %Define

Execute
  Let mystack = stringStack(50).
  Ask mystack => Push("horse"). %Ask
  Line[$(Ask mystack => pop().)].
  Check["\"horse\""].
%Execute

%Package

